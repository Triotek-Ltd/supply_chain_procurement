{
  "display": {
    "title_template": "{title}",
    "subtitle_template": "{reference_no}",
    "list_columns": [
      "title",
      "reference_no",
      "posting_date",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "stock_item",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "warehouse_record",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "inventory_movement",
      "relation_type": "related",
      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "warehouse",
      "doc_id": "warehouse_record",
      "lookup_mode": "single",
      "purpose": "relation_reference"
    },
    {
      "field_id": "related_inventory_movement",
      "doc_id": "inventory_movement",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    }
  ],
  "fetch_rules": [
    {
      "field_id": "warehouse",
      "source_doc_id": "warehouse_record",
      "fetch_profile": "display_identity",
      "fetch_fields": [
        "title",
        "reference_no"
      ],
      "purpose": "relation_reference"
    }
  ],
  "reference_map": {
    "primary_reference_field": "reference_no",
    "reference_labels": []
  },
  "relation_rules": {
    "parent_doc": null,
    "child_docs": [
      "inventory_movement"
    ],
    "show_related_panel": true
  },
  "borrowed_fields": [
    {
      "description": "item identity from stock_item"
    },
    {
      "description": "warehouse identity from warehouse_record"
    }
  ],
  "ui_panels": {
    "show_activity_log": true,
    "show_comments": true,
    "show_assignments": true,
    "show_related_docs": true
  },
  "integration": {
    "external_refs": [],
    "sync_rules": []
  },
  "runtime_hints": {
    "doc_key": "inventory_balance",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "receive, verify, store, monitor, count, reconcile, and replenish inventory accurately",
      "actors": [
        "storekeeper",
        "warehouse operator",
        "inventory controller",
        "reviewer"
      ],
      "start_condition": "stock is received, moved, counted, or adjusted",
      "ordered_steps": [
        "Update the inventory balance position.",
        "Monitor stock levels and trigger recount or replenishment as needed."
      ],
      "primary_actions": [
        "create",
        "review"
      ],
      "primary_transitions": [
        "inventory_balance: active"
      ],
      "downstream_effects": [
        "inventory availability feeds purchasing, warehouse execution, logistics, and production planning"
      ],
      "action_actors": {
        "create": [
          "storekeeper"
        ],
        "review": [
          "reviewer"
        ],
        "archive": [
          "storekeeper"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  }
}

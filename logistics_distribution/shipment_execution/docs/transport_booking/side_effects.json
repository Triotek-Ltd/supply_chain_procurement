{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "submit": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "submitted"
      }
    }
  ],
  "confirm": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "confirmed"
      }
    },
    {
      "type": "create_record",
      "target_doc": "shipment_record",
      "values": {
        "title": {
          "$template": "Shipment Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "SHIPMENT_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "cancel": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "cancelled"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}

{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ],
  "dispatch": [
    {
      "type": "create_record",
      "target_doc": "courier_shipment_request",
      "values": {
        "title": {
          "$template": "Courier Shipment Request for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "COURIER_SHIPMENT_REQUEST-{reference_no|id}"
        },
        "source_reference": {
          "$from": [
            "reference_no",
            "id"
          ]
        },
        "source_doc_id": {
          "$template": "{id}"
        }
      }
    }
  ]
}

{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ],
  "assign": [
    {
      "type": "create_record",
      "target_doc": "putaway_task",
      "values": {
        "title": {
          "$template": "Putaway Task for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "PUTAWAY_TASK-{reference_no|id}"
        }
      }
    }
  ]
}

{
  "display": {
    "title_template": "{title}",
    "subtitle_template": "{reference_no}",
    "list_columns": [
      "title",
      "reference_no",
      "posting_date",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "supplier_profile",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "supplier_qualification",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "vendor_contract",
      "relation_type": "related",
      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "supplier",
      "doc_id": "supplier_profile",
      "lookup_mode": "single",
      "purpose": "party_reference"
    },
    {
      "field_id": "related_supplier_qualification",
      "doc_id": "supplier_qualification",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_vendor_contract",
      "doc_id": "vendor_contract",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    }
  ],
  "fetch_rules": [
    {
      "field_id": "supplier",
      "source_doc_id": "supplier_profile",
      "fetch_profile": "supplier_profile",
      "fetch_fields": [
        "title",
        "reference_no",
        "supplier_code",
        "email",
        "phone",
        "contact_email",
        "contact_phone"
      ],
      "purpose": "party_reference"
    }
  ],
  "reference_map": {
    "primary_reference_field": "reference_no",
    "reference_labels": []
  },
  "relation_rules": {
    "parent_doc": null,
    "child_docs": [
      "supplier_qualification",
      "vendor_contract"
    ],
    "show_related_panel": true
  },
  "borrowed_fields": [
    {
      "description": "supplier identity"
    },
    {
      "description": "contract/SLA context from linked docs"
    }
  ],
  "ui_panels": {
    "show_activity_log": true,
    "show_comments": true,
    "show_assignments": true,
    "show_related_docs": true
  },
  "integration": {
    "external_refs": [],
    "sync_rules": []
  },
  "runtime_hints": {
    "doc_key": "vendor_review",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "maintain supplier master quality, review vendor performance, and resolve supplier issues proactively",
      "actors": [
        "vendor manager",
        "reviewer",
        "legal/procurement owner"
      ],
      "start_condition": "a supplier is onboarded or reviewed",
      "ordered_steps": [
        "Review supplier performance and compliance status."
      ],
      "primary_actions": [
        "create",
        "review",
        "close"
      ],
      "primary_transitions": [
        "vendor_review: opened -> reviewed -> closed"
      ],
      "downstream_effects": [
        "supports sourcing, purchase control, and risk management"
      ],
      "action_actors": {
        "create": [
          "vendor manager"
        ],
        "review": [
          "reviewer"
        ],
        "archive": [
          "legal/procurement owner"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  }
}

  "runtime_hints": {
    "doc_key": "vendor_review",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "maintain supplier master quality, review vendor performance, and resolve supplier issues proactively",
      "actors": [
        "vendor manager",
        "reviewer",
        "legal/procurement owner"
      ],
      "start_condition": "a supplier is onboarded or reviewed",
      "ordered_steps": [
        "Review supplier performance and compliance status."
      ],
      "primary_actions": [
        "create",
        "review",
        "close"
      ],
      "primary_transitions": [
        "vendor_review: opened -> reviewed -> closed"
      ],
      "downstream_effects": [
        "supports sourcing, purchase control, and risk management"
      ],
      "action_actors": {
        "create": [
          "vendor manager"
        ],
        "review": [
          "reviewer"
        ],
        "archive": [
          "legal/procurement owner"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  },
  "dashboard": {
    "metric_blocks": [
      "kpis",
      "summaries",
      "charts",
      "reports",
      "records"
    ],
    "default_view": "list",
    "reporting_surface": "doc"
  }

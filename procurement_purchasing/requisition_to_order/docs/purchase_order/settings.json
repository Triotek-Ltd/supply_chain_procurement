{
  "display": {
    "title_template": "{title}",
    "subtitle_template": "{reference_no}",
    "list_columns": [
      "title",
      "reference_no",
      "transaction_date",
      "party",
      "total_amount",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "purchase_requisition",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "goods_receipt",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "supplier_invoice",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "supplier_profile",
      "relation_type": "related",
      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "supplier",
      "doc_id": "supplier_profile",
      "lookup_mode": "single",
      "purpose": "party_reference"
    },
    {
      "field_id": "related_purchase_requisition",
      "doc_id": "purchase_requisition",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_goods_receipt",
      "doc_id": "goods_receipt",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_supplier_invoice",
      "doc_id": "supplier_invoice",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    }
  ],
  "fetch_rules": [
    {
      "field_id": "supplier",
      "source_doc_id": "supplier_profile",
      "fetch_profile": "supplier_profile",
      "fetch_fields": [
        "title",
        "reference_no",
        "supplier_code",
        "email",
        "phone",
        "contact_email",
        "contact_phone"
      ],
      "purpose": "party_reference"
    }
  ],
  "reference_map": {
    "primary_reference_field": "reference_no",
    "reference_labels": []
  },
  "relation_rules": {
    "parent_doc": null,
    "child_docs": [
      "purchase_requisition",
      "goods_receipt",
      "supplier_invoice"
    ],
    "show_related_panel": true
  },
  "borrowed_fields": [
    {
      "description": "supplier"
    },
    {
      "description": "request details from supplier_profile"
    },
    {
      "description": "purchase_requisition"
    }
  ],
  "ui_panels": {
    "show_activity_log": true,
    "show_comments": true,
    "show_assignments": true,
    "show_related_docs": true
  },
  "integration": {
    "external_refs": [],
    "sync_rules": []
  },
  "runtime_hints": {
    "doc_key": "purchase_order",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "convert an internal purchasing need into an approved purchase order issued to the right supplier",
      "actors": [
        "requesting department",
        "procurement officer",
        "reviewer",
        "approver",
        "supplier"
      ],
      "start_condition": "a department raises a purchasing need",
      "ordered_steps": [
        "Create and issue the purchase order.",
        "Record the committed procurement obligation."
      ],
      "primary_actions": [
        "create",
        "review",
        "approve",
        "issue"
      ],
      "primary_transitions": [
        "purchase_order: draft -> submitted -> approved"
      ],
      "downstream_effects": [
        "purchase orders feed goods receipt, supplier invoice matching, and vendor performance tracking"
      ],
      "action_actors": {
        "create": [
          "requesting department"
        ],
        "review": [
          "reviewer"
        ],
        "approve": [
          "approver"
        ],
        "issue": [
          "requesting department"
        ],
        "close": [
          "requesting department"
        ],
        "archive": [
          "requesting department"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  }
}

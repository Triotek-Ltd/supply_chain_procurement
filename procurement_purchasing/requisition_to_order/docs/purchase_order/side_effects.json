{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ],
  "issue": [
    {
      "type": "create_record",
      "target_doc": "supplier_invoice",
      "values": {
        "title": {
          "$template": "Supplier Invoice for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "SUPPLIER_INVOICE-{reference_no|id}"
        }
      }
    }
  ]
}

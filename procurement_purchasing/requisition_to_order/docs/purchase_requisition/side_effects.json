{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "submit": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "submitted"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "procurement_request",
      "values": {
        "title": {
          "$template": "Procurement Request for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "PROCUREMENT_REQUEST-{reference_no|id}"
        }
      }
    }
  ],
  "cancel": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "cancelled"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
